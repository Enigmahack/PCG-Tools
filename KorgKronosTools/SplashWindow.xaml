<Window x:Class="PcgTools.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Topmost="True" 
        Icon="/PcgTools;component/Gui/pcgtools.ico" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" WindowStyle="None" Focusable="False" 
        SizeToContent="WidthAndHeight">
    <Border Background="#FF1E1E1E" BorderBrush="#FF007ACC" BorderThickness="1">
        <StackPanel>
            <Image HorizontalAlignment="Left" Name="imageDonator" Stretch="Fill" VerticalAlignment="Top" Width="350"
                   Source="/PcgTools;component/Gui/Images/pcgtoolsnormal.jpg" Margin="0"/>

            <Border Background="#FF252526" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Version, Source={StaticResource LocStrings}}"
                                       Foreground="#FF9D9D9D" VerticalAlignment="Center"/>
                            <TextBlock Name="labelVersion" Text="&lt;x.y.z&gt;"
                                       Foreground="#FFCCCCCC" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DevelopedBy, Source={StaticResource LocStrings}}"
                                   Foreground="#FF9D9D9D" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding SponsoredBy, Source={StaticResource LocStrings}}"
                                       Foreground="#FF9D9D9D"/>
                            <TextBlock Name="labelSponsorName" Text="&lt;Sponsor name&gt;"
                                       Foreground="#FFCCCCCC" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Image Grid.Column="1" Margin="8,0,0,0" Name="image" Stretch="Fill"/>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</Window>
